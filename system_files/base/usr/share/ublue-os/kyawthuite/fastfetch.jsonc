{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "display": {},
  "modules": [
    {
      "type": "os",
      "format": "{name}",
    },
    {
      "type": "cpu",
      "format": "{name} ({cores-logical})",
    },
    {
      "type": "gpu",
      "detectionMethod": "vulkan",
      "format": "{name}",
    },
    "memory",
    "swap",
    "uptime",
    "packages",
  ],
}
