#!/usr/bin/env python3

from dnf.const import PROGRAM_NAME
import argparse
import subprocess
import sys
from pathlib import Path

PROGRAM_NAME = "kw"

BLUE_COLOR = "\033[1;34m"
RED_COLOR = "\033[1;31m"
RESET = "\033[0m"

# logging
class Log:
    def __init__(self) -> None:
        pass

    def info(self, message):
        print(f"{BLUE_COLOR}[sys] {message}{RESET}")

    def error(self, message):
        print(f"{RED_COLOR}[sys] {message}{RESET}", file=sys.stderr)
_log = Log()
        
        
# helpers
def _confirm(prompt: str) -> None:
    """Print prompt and exit unless user answers y/Y."""
    answer = input(f"{BLUE_COLOR}[{PROGRAM_NAME}] {prompt}{RESET} ")
    if answer.strip().lower() != "y":
        print("Aborted.")
        sys.exit(0)


def _run(cmd: list[str], check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd,
        check=check,
        capture_output=capture,
        text=True,
    )


def _dir_size(*paths: str) -> int:
    total = 0
    for path in paths:
        result = subprocess.run(
            ["du", "-sb", path],
            capture_output=True, text=True, check=False,
        )
        for line in result.stdout.splitlines():
            parts = line.split()
            if parts:
                try:
                    total += int(parts[0])
                except ValueError:
                    pass
    return total


def bytes_to_mb(n: int) -> str:
    return f"{n / 1024 / 1024:.2f} MB"


# main functionality
def cmd_update(_args: argparse.Namespace) -> None:
    _confirm("Check for updates without applying them? [y/N]:")

    _log.info("==> Checking bootc...")
    result = subprocess.run(
        ["sudo", "bootc", "upgrade", "--check"],
        capture_output=True, text=True, check=False,
    )
    output = result.stdout + result.stderr
    if "update available" in output.lower():
        version = ""
        for line in output.splitlines():
            if "Version:" in line:
                version = line.split(":", 1)[-1].strip()
                break
        if version:
            _log.info(f"bootc update available: {version}")
        else:
            _log.error("bootc update available but could not determine version. Run: sudo bootc upgrade --check")
    else:
        _log.info("bootc: up to date")

    _log.info("==> Checking flatpak...")
    result = subprocess.run(
        ["flatpak", "remote-ls", "--updates"],
        capture_output=True, text=True, check=False,
    )
    if result.returncode != 0:
        _log.error("Could not check flatpak updates. Run: flatpak remote-ls --updates")
    else:
        updates = [l for l in result.stdout.splitlines() if l.strip()]
        if updates:
            _log.info(f"flatpak: {len(updates)} update(s) available")
        else:
            _log.info("flatpak: up to date")

    _log.info("==> Checking brew...")
    refresh = subprocess.run(["brew", "update"], capture_output=True, check=False)
    if refresh.returncode != 0:
        _log.error("Could not refresh brew metadata. Run: brew update")
    else:
        result = subprocess.run(["brew", "outdated"], capture_output=True, text=True, check=False)
        if result.returncode != 0:
            _log.error("Could not check brew updates. Run: brew outdated")
        else:
            updates = [l for l in result.stdout.splitlines() if l.strip()]
            if updates:
                _log.info(f"brew: {len(updates)} update(s) available")
            else:
                _log.info("brew: up to date")


def cmd_upgrade(_args: argparse.Namespace, reboot: bool = False) -> None:
    if reboot:
        _confirm("Apply all available updates and reboot? [y/N]:")
    else:
        _confirm("Apply all available updates now? [y/N]:")

    _log.info("==> Upgrading bootc...")
    _run(["sudo", "bootc", "upgrade"])

    _log.info("==> Upgrading flatpak...")
    _run(["flatpak", "update", "-y"])

    _log.info("==> Upgrading brew...")
    _run(["brew", "upgrade", "--force"])

    _log.info("==> Done.")
    
    if reboot:
        _log.info("==> Rebooting...")
        _run(["sudo", "reboot"])
    

def cmd_cleanup(_args: argparse.Namespace) -> None:
    _confirm("Remove unused flatpak runtimes and old brew packages? [y/N]:")

    brew_prefix = subprocess.run(
        ["brew", "--prefix"], capture_output=True, text=True, check=False,
    ).stdout.strip()
    brew_cache = str(Path.home() / ".cache" / "Homebrew")
    flatpak_system = "/var/lib/flatpak"
    flatpak_user = str(Path.home() / ".local" / "share" / "flatpak")

    brew_before    = _dir_size(brew_prefix, brew_cache)
    flatpak_before = _dir_size(flatpak_system, flatpak_user)

    _log.info("==> Removing unused flatpak runtimes...")
    _run(["flatpak", "uninstall", "--unused", "-y"])

    _log.info("==> Cleaning brew cache...")
    _run(["brew", "cleanup"])

    brew_freed    = brew_before    - _dir_size(brew_prefix, brew_cache)
    flatpak_freed = flatpak_before - _dir_size(flatpak_system, flatpak_user)
    total_freed   = brew_freed + flatpak_freed

    _log.info(
        f"==> Freed: {bytes_to_mb(total_freed)}"
        f"  (brew: {bytes_to_mb(brew_freed)}, flatpak: {bytes_to_mb(flatpak_freed)})"
    )


def main() -> None:
    parser = argparse.ArgumentParser(
        prog=PROGRAM_NAME,
        description="System maintenance: updates, upgrades, and cleanup.",
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    sub.add_parser(
        "update",
        help="Check for available updates without applying them",
        description="Checks bootc, flatpak, and brew for available updates. Nothing is installed or changed.",
    )
    sub.add_parser(
        "upgrade",
        help="Apply all available updates",
        description="Runs bootc upgrade, flatpak update, and brew upgrade. A reboot may be required for bootc changes.",
    )
    sub.add_parser(
        "upgrade-reboot",
        help="Apply all available updates, then reboot",
        description="Same as 'upgrade', then reboots the system immediately.",
    )
    sub.add_parser(
        "cleanup",
        help="Remove unused flatpak runtimes and old brew packages",
        description="Removes unused flatpak runtimes and old brew package versions. Reports disk space freed.",
    )

    args = parser.parse_args()

    dispatch = {
        "update":         cmd_update,
        "upgrade":        cmd_upgrade,
        "upgrade-reboot": lambda args: cmd_upgrade(args, reboot=True),
        "cleanup":        cmd_cleanup,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()